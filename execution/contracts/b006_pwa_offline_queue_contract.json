{
  "bead_id": "B-006",
  "name": "PWA Offline Queue Contract",
  "version": "1.0.0",
  "status": "draft",
  "scope": {
    "channel": "pwa",
    "focus": [
      "enqueue",
      "replay",
      "dedupe",
      "reconciliation",
      "connectivity_downgrade_prompt"
    ]
  },
  "queue_item": {
    "required_fields": [
      "item_id",
      "idempotency_key",
      "workflow_id",
      "intent",
      "payload",
      "created_at",
      "attempt_count",
      "state"
    ],
    "state_enum": [
      "queued",
      "replaying",
      "acked",
      "failed_retryable",
      "failed_terminal",
      "cancelled"
    ]
  },
  "transitions": {
    "queued": [
      "replaying",
      "cancelled"
    ],
    "replaying": [
      "acked",
      "failed_retryable",
      "failed_terminal"
    ],
    "failed_retryable": [
      "queued",
      "replaying",
      "failed_terminal"
    ],
    "acked": [],
    "failed_terminal": [],
    "cancelled": []
  },
  "dedupe": {
    "strategy": "idempotency_key",
    "duplicate_result": "acked_existing"
  },
  "replay_policy": {
    "ordering": "created_at_asc",
    "max_attempts": 5,
    "backoff_seconds": [1, 5, 15, 30, 60]
  },
  "connectivity": {
    "degraded_actions": [
      "queue_and_notify",
      "prompt_channel_handoff"
    ],
    "handoff_priority": [
      "whatsapp",
      "ussd",
      "sms"
    ]
  },
  "telemetry": {
    "required_events": [
      "queue_item_enqueued",
      "queue_replay_started",
      "queue_replay_acked",
      "queue_replay_failed",
      "channel_handoff_prompted"
    ]
  }
}

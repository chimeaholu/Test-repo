{
  "bead_id": "B-005",
  "name": "WhatsApp Adapter Contract",
  "version": "1.0.0",
  "status": "draft",
  "scope": {
    "channel": "whatsapp",
    "focus": [
      "inbound_normalization",
      "command_intent_parsing",
      "template_strategy",
      "fallback_hooks"
    ]
  },
  "inbound_message": {
    "required_fields": [
      "message_id",
      "contact_id",
      "message_type",
      "locale"
    ],
    "message_type_enum": [
      "text",
      "interactive",
      "template",
      "unknown"
    ]
  },
  "intent_parser": {
    "supported_intents": [
      "help",
      "create_listing",
      "negotiation_reply",
      "settlement_status",
      "unknown"
    ],
    "interactive_payload_format": "key:value|key:value"
  },
  "templates": {
    "supported_events": [
      "settlement_update",
      "listing_alert"
    ],
    "default_locale": "en",
    "fallback_policy": {
      "delivery_failed": "sms",
      "session_window_expired": "sms",
      "network_degraded": "ussd"
    }
  }
}

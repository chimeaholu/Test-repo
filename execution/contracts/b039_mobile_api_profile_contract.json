{
  "bead_id": "B-039",
  "name": "Mobile API Profile and Payload Budget Spec",
  "version": "1.0.0",
  "status": "draft",
  "scope": {
    "channel": "mobile_api",
    "focus": [
      "payload_budget",
      "pagination",
      "resumable_operations",
      "version_negotiation"
    ]
  },
  "versioning": {
    "strategy": "backward_compatible_profile_negotiation",
    "supported_versions": [
      "2026-03-01",
      "2026-04-13"
    ]
  },
  "payload_budgets": {
    "market.listings.index": {
      "max_bytes": 240,
      "max_items": 3
    },
    "market.offers.mutate": {
      "max_bytes": 180
    }
  },
  "pagination": {
    "default_page_size": 20,
    "max_page_size": 50,
    "cursor_parameter": "cursor"
  },
  "resumable_operations": {
    "market.offers.mutate": {
      "operation_token_required": true,
      "token_ttl_seconds": 900,
      "contract_tool_name": "market.update_offer"
    }
  },
  "test_obligations": {
    "journeys": [
      "ARJ-001",
      "ARJ-004"
    ],
    "data_check": "ARDI-001"
  }
}

            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "supported_locales": {
          "items": {
            "$ref": "#/definitions/CountryPack/properties/default_locale"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "country_code",
        "region",
        "currency",
        "default_locale",
        "supported_locales",
        "supported_channels",
        "legal_notices",
        "regulated_mutation_requires_consent"

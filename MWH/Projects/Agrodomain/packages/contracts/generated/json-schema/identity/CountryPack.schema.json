          "pattern": "^[A-Z]{2}$",
          "type": "string"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "type": "string"
        },
        "default_locale": {
          "maxLength": 16,
          "minLength": 2,
          "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$",
          "type": "string"
        },
        "legal_notices": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "body_markdown": {
                "minLength": 1,
                "type": "string"
              },
              "locale": {
                "$ref": "#/definitions/CountryPack/properties/default_locale"
              },
              "notice_id": {
                "minLength": 1,
                "type": "string"
              },
              "required_for_scopes": {
                "items": {
                  "minLength": 1,
                  "type": "string"
                },
                "minItems": 1,
                "type": "array"
              },
              "title": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "notice_id",
              "locale",
              "title",
              "body_markdown",
              "required_for_scopes"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        },
        "region": {
          "minLength": 1,
          "type": "string"
        },
        "regulated_mutation_requires_consent": {
          "type": "boolean"
        },
        "schema_version": {
          "enum": [
            "2026-04-18.wave1"
          ],
          "type": "string"
        },
        "supported_channels": {
          "items": {
            "enum": [
              "ussd",
              "whatsapp",
              "pwa",
              "sms"

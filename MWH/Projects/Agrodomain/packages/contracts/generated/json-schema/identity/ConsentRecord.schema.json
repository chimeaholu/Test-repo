{
  "$ref": "#/definitions/ConsentRecord",
  "definitions": {
    "ConsentRecord": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "type": "string"
        },
        "consent_captured_at": {
          "description": "ISO-8601 timestamp with timezone offset",
          "format": "date-time",
          "nullable": true,
          "type": "string"
        },
        "consent_channel": {
          "description": "Transport channel that originated or carried the request",
          "enum": [
            "pwa",
            "ussd",
            "whatsapp",
            "sms",
            "push",
            "api"
          ],
          "nullable": true,
          "type": "string"
        },
        "consent_revoked_at": {
          "allOf": [
            {
              "$ref": "#/definitions/ConsentRecord/properties/consent_captured_at"
            }
          ],
          "description": "ISO-8601 timestamp with timezone offset",
          "nullable": true
        },
        "consent_scope_ids": {
          "default": [],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "country_code": {
          "description": "ISO alpha-2 country code",
          "pattern": "^[A-Z]{2}$",
          "type": "string"
        },
        "policy_version": {
          "minLength": 1,
          "nullable": true,
          "type": "string"
        },
        "schema_version": {
          "enum": [
            "2026-04-18.wave1"
          ],
          "type": "string"
        },
        "state": {
          "enum": [
            "identified",
            "consent_pending",
            "consent_granted",
            "consent_revoked"
          ],
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "actor_id",
        "country_code",
        "state"
      ],
      "type": "object"
    }
  },
  "description": "Consent lifecycle snapshot used by workflow, audit, and regulated mutation guards.",

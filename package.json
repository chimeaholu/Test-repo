{
  "name": "agrodomain",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "corepack pnpm -r --filter @agrodomain/api --filter @agrodomain/worker --filter @agrodomain/web --filter @agrodomain/contracts --filter @agrodomain/config run build",
    "lint": "corepack pnpm -r --filter @agrodomain/api --filter @agrodomain/worker --filter @agrodomain/web --filter @agrodomain/contracts --filter @agrodomain/config run lint",
    "typecheck": "corepack pnpm -r --filter @agrodomain/api --filter @agrodomain/worker --filter @agrodomain/web --filter @agrodomain/contracts --filter @agrodomain/config run typecheck",
    "test": "corepack pnpm -r --filter @agrodomain/api --filter @agrodomain/worker --filter @agrodomain/web --filter @agrodomain/contracts --filter @agrodomain/config run test",
    "test:e2e": "playwright test",
    "guard:release-proof": "node scripts/verify-release-proof.mjs",
    "test:e2e:report": "node scripts/write-playwright-report.mjs",
    "ci:artifacts": "node scripts/collect-ci-artifacts.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2.5.3"
  }
}

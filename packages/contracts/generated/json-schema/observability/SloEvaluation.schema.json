{
  "$ref": "#/definitions/SloEvaluation",
  "definitions": {
    "SloEvaluation": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "type": "string"
        },
        "alert_severity": {
          "enum": [
            "none",
            "info",
            "warning",
            "critical"
          ],
          "nullable": true,
          "type": "string"
        },
        "audit_event_id": {
          "minimum": 0,
          "type": "integer"
        },
        "breach_count": {
          "minimum": 0,
          "type": "integer"
        },
        "channel": {
          "description": "Transport channel that originated or carried the request",
          "enum": [
            "pwa",
            "ussd",
            "whatsapp",
            "sms",
            "push",
            "api"
          ],
          "type": "string"
        },
        "country_code": {
          "description": "ISO alpha-2 country code",
          "pattern": "^[A-Z]{2}$",
          "type": "string"
        },
        "evaluated_at": {
          "$ref": "#/definitions/SloEvaluation/properties/window_started_at"
        },
        "objective_kind": {
          "enum": [
            "success_rate",
            "latency_p95_ms",
            "freshness_seconds"
          ],
          "type": "string"
        },
        "objective_target": {
          "minimum": 0,
          "type": "number"
        },
        "observed_value": {
          "minimum": 0,
          "nullable": true,
          "type": "number"
        },
        "rationale": {
          "maxLength": 320,
          "minLength": 8,
          "type": "string"
        },
        "request_id": {
          "minLength": 1,
          "type": "string"
        },
        "schema_version": {
          "enum": [
            "2026-04-18.wave1"
          ],
          "type": "string"
        },
        "service_name": {
          "enum": [
            "admin_control_plane",
            "marketplace",
            "advisory",
            "finance",
            "traceability",
            "climate",
            "rollout_control"
          ],
          "type": "string"
        },
        "slo_id": {
          "maxLength": 32,
          "minLength": 1,
          "nullable": true,
          "type": "string"
        },
        "status": {
          "enum": [
            "healthy",
            "degraded",
            "breached",
            "unavailable"
          ],
          "type": "string"
        },
        "supporting_observation_ids": {
          "items": {
            "maxLength": 96,
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "window_ended_at": {
          "allOf": [
            {
              "$ref": "#/definitions/SloEvaluation/properties/window_started_at"
            }
          ],
          "description": "ISO-8601 timestamp with timezone offset",
          "nullable": true
        },
        "window_started_at": {
          "description": "ISO-8601 timestamp with timezone offset",
          "format": "date-time",
          "nullable": true,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "request_id",
        "actor_id",
        "country_code",
        "channel",
        "service_name",
        "slo_id",
        "alert_severity",
        "audit_event_id",
        "objective_kind",
        "objective_target",
        "observed_value",
        "status",
        "breach_count",
        "window_started_at",
        "window_ended_at",
        "supporting_observation_ids",
        "rationale",
        "evaluated_at"
      ],
      "type": "object"
    }
  },
  "description": "SLO evaluation result describing observed value, threshold, severity, and supporting telemetry evidence for operator actions.",
  "x-agrodomain-contract": {
    "id": "observability.slo_evaluation",
    "domain": "observability",
    "kind": "dto",
